#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import os
import subprocess
import pandas as pd


def process_struct_file(predicted_struct_path, motif_path, output_path):
    """
    Create a .forrest file suitable for RNAforester by comparing predicted structures
    to a target motif structure. Each sample will include:

        >sampleN
        predicted_structure
        motif_structure
    """
    with open(motif_path, 'r') as mf:
        motif = mf.read().strip()

    lines = []
    with open(predicted_struct_path, 'r') as f:
        sample_num = 0
        for line in f:
            line = line.strip()
            if line.startswith(">"):
                lines.append(f">sample{sample_num}")
                sample_num += 1
            elif any(c in ".()[]" for c in line):  # structure line
                lines.append(line)
                lines.append(motif)

    with open(output_path, 'w') as out:
        out.write("\n".join(lines) + "\n")

def split_file(input_file, output_prefix, lines_per_file):
    part_num = 0
    current_lines = []
    part_files = []
    with open(input_file, 'r') as infile:
        for line_num, line in enumerate(infile, 1):
            current_lines.append(line)
            if line_num % lines_per_file == 0:
                output_file = f"{output_prefix}--part{part_num}.forrest"
                with open(output_file, 'w') as outfile:
                    outfile.writelines(current_lines)
                part_files.append(output_file)
                current_lines = []
                part_num += 1
        # Write any remaining lines
        if current_lines:
            output_file = f"{output_prefix}--part{part_num}.forrest"
            with open(output_file, 'w') as outfile:
                outfile.writelines(current_lines)
            part_files.append(output_file)
    return part_files


def process_chunk_with_rnaforester(chunk_lines, outfile, part_num):
    """
    This function processes a chunk of lines using RNAforester and writes the result to the output file.
    """
    # Write the chunk to a temporary file
    temp_input_file = f"temp_part{part_num}.forrest"
    temp_output_file = f"temp_part{part_num}.score"
    
    with open(temp_input_file, 'w') as temp_file:
        temp_file.writelines(chunk_lines)

    # Call RNAforester on the temporary input file and write output to a temporary output file
    subprocess.run(f"RNAforester --score -f {temp_input_file} > {temp_output_file}", shell=True, check=True)

    # Append the result to the final output file
    with open(temp_output_file, 'r') as temp_outfile:
        outfile.writelines(temp_outfile.readlines())

    # Clean up the temporary files
    os.remove(temp_input_file)
    os.remove(temp_output_file)

import subprocess

def process_with_rnaforester(input_file, output_file):
    """
    Processes the entire input file with RNAforester in one go, without using a temp file.
    """
    try:
        result = subprocess.run(
            #changed to relative score r not absolute
            ["RNAforester","-r","--score", "-f", input_file],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=True,
            text=True  # decode bytes to str automatically
        )
    except subprocess.CalledProcessError as e:
        raise RuntimeError(f"RNAforester failed:\n{e.stderr}")
    #old logic. New one writes 2 lines (both absolute and relative score)
    #save relative and absolute scores
    #with open(output_file, 'w') as f:
    #    f.write(result.stdout)
    lines = [l.strip() for l in result.stdout.splitlines() if l.strip()]

    # raw scores are 0,2,4,... and relative scores are 1,3,5,...
    raw_scores = lines[0::2]
    rel_scores = lines[1::2]

    # write relative scores to the declared output file
    with open(output_file, "w") as f:
        f.write("\n".join(rel_scores) + "\n")

    # create a sidecar file for raw scores
    abs_file = output_file + ".abs"
    with open(abs_file, "w") as f:
        f.write("\n".join(raw_scores) + "\n")
######last step = extracting best sample(s)
def extract_best_samples(scores,struct,out_file,n=1):
    scores = pd.read_csv(scores,sep="\t",header=None)
    
    lines = []
    with open(struct) as f:
        for line in f:
            lines.append(line.strip())
    
    with open(out_file,"w") as f:        
        for index in scores[0].nlargest(n).index:
            f.write(lines[index*3]+" "+str(scores.loc[index,0])+"\n")
            f.write(lines[(index*3)+1]+"\n")
            f.write(lines[(index*3)+2]+"\n")


