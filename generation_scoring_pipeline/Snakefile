rule mxfold2_predict:
    input:
        "intermediate/{motif}/{file}.fasta"
    output:
        "intermediate/{motif}/{file}.struct"  # Ensure motif is in output filename
    conda:
        "mxfold.yaml"
    threads:
        lambda wildcards: min(24, workflow.cores)
    shell:
        """
        export OMP_NUM_THREADS={threads}
        export MKL_NUM_THREADS={threads}
        mxfold2 predict {input} > {output}
        """

rule python_processing:
    input:
        motif="motifs/{motif}.txt",  # Motif file
        sequence_file="intermediate/{motif}/{file}.struct"  # Sequence file from mxfold2_predict
    output:
        temp("intermediate/{motif}/{file}.forrest")  # Output includes both motif and file
    run:
        # Call the Python function to process the sequence and motif
        process_struct_file(input.sequence_file, input.motif, output[0])

rule process_rnaforester:
    input:
        "intermediate/{motif}/{file}.forrest"
    output:
        "results/{motif}/{file}.score"
    resources:
        rnaforester_slots = 1
    threads: 8
    run:
        #process_with_rnaforester(input[0], output[0], lines_per_chunk=9000)
        process_with_rnaforester(input[0], output[0])

rule extrac_best:
    input:
        score="results/{motif}/{file}.score",
        struct="intermediate/{motif}/{file}.struct"
    output:
        "output/{motif}/{file}.fasta"
    run:
        extract_best_samples(input.score,input.struct,output[0],10)